{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-destructive-git.py" }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit|NotebookEdit|Grep|Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-env-read.py" }
        ]
      }
    ]
  }
}
